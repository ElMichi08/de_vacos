# Variables de Entorno para De Vacos Urban Grill
# Copia este archivo a .env y completa con tus valores reales

# URL de tu proyecto Supabase
SUPABASE_URL=tu_url_supabase_aqui

# Clave anónima (anon public key) de Supabase
# Encuéntrala en: Settings > API > anon public
SUPABASE_ANON_KEY=tu_clave_anon_aqui

# ID del cliente para identificación en Supabase
# Este ID debe coincidir con el cliente_id en las tablas de Supabase
CLIENTE_ID=tu_cliente_id_aqui