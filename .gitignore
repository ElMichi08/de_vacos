# Ignorar todo por defecto
*

# Incluir explícitamente el contenido de /lib (toda la programación)
!lib/
!lib/**

# Tests (flutter_test)
!test/
!test/**

# Assets (branding config, etc.)
!assets/
!assets/**

# Documentación
!README.md
!AGENTS.md
!docs/
!docs/**

# Configuración de agentes y skills
!opencode.json
!.agents/
!.agents/**

# Incluir logo (png o jpg)
!logo.png
!logo.jpg

# Incluir icono de la app
!icon_app.png

# Incluir configuraciones de dependencias de Flutter
!pubspec.yaml
!pubspec.lock
!analysis_options.yaml

# Variables de entorno con credenciales (NUNCA commitear)
.env

# Referencia de variables de entorno (sin credenciales)
!env.example

# Mantener la estructura de .gitignore
!.gitignore
